# Home Dashboard — environment configuration
# Copy this file to `.env` and fill in your values.

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Weather (OpenMeteo, no API key required) ---
# Defaults are Sopot, Poland.
WEATHER_LAT=54.4418
WEATHER_LON=18.5601
WEATHER_CITY=Sopot

# --- iCloud calendars ---
# Add one URL per calendar. The backend reads every variable
# whose name starts with ICAL_URL_. Order does not matter.
# Format: https://p09-caldav.icloud.com/published/2/.....ics
# `webcal://` URLs are accepted and rewritten to `https://`.
ICAL_URL_1=
ICAL_URL_2=
ICAL_URL_3=
